<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Sign In</title>

<link rel="stylesheet" href="/css/auth.css">

</head>


<body>


<% if (error) { %>

<div class="notification">

    <%= error %>

</div>

<% } %>



<div class="auth-card">


<h1 class="logo">
Empty Account
</h1>



<h2>
Sign In
</h2>



<form action="/signin" method="POST">



<label>
Username
</label>


<input
type="text"
name="username"
placeholder="Enter username"
required
>




<label>
Password
</label>


<input
type="password"
name="password"
placeholder="Enter password"
required
>



<button type="submit">

Sign In

</button>



</form>




<p class="bottom-text">


Don't have an account?


<a href="/signup">

Sign Up

</a>


</p>



</div>



</body>

</html>
