<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Sign Up</title>

    <link rel="stylesheet" href="/css/auth.css">

</head>

<body>

    <!-- Баннер ошибок (пока скрыт) -->
    <div class="notification hidden">

        Username is already taken.

    </div>


    <div class="auth-card">

        <h1 class="logo">

            Empty Account

        </h1>


        <h2>

            Sign Up

        </h2>


        <form>

            <label>

                Username

            </label>

            <input
                type="text"
                placeholder="Choose a username"
                autocomplete="username"
            >


            <label>

                Display Name

            </label>

            <input
                type="text"
                placeholder="Your display name"
            >


            <label>

                Password

            </label>

            <input
                type="password"
                placeholder="Create a password"
                autocomplete="new-password"
            >


            <button type="submit">

                Create Account

            </button>

        </form>


        <p class="bottom-text">

            Already have an account?

            <a href="/signin">

                Sign In

            </a>

        </p>

    </div>

</body>

</html>
